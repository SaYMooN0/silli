program FactorialProgram;

var
    inter : string;

procedure CalcFactorial(n : integer; cap :string);
begin
    if n <= 1 then
    begin
        inter := "empty";
        ;
        ;
    end
    else
    begin
        inter := cap*(n);    
        CalcFactorial(n - 1, cap*(n-1));
    end;
end;

begin
    CalcFactorial(4, "-");
end.